DATABASE_URL=postgres://jobsignal:jobsignal@localhost:5432/jobsignal
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
NODE_ENV=development
BULL_BOARD_USER=admin
BULL_BOARD_PASS=admin
# Grace period (ms) on SIGTERM before releasing resources, so a load balancer
# can observe /health/ready failing and drain. 0 for local; ~8000 behind a proxy.
SHUTDOWN_GRACE_MS=0
JWT_SECRET=change-me-in-production
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# S3 / MinIO for streaming exports (Layer 5). Defaults target local MinIO.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_EXPORT_BUCKET=job-exports
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
