{
  "uid": "job-signal",
  "title": "Job Signal",
  "tags": ["job-signal"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "bargauge",
      "title": "Jobs scraped by source & outcome",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (source, outcome) (jobs_scraped_total)",
          "legendFormat": "{{source}} · {{outcome}}",
          "instant": true,
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "continuous-GrYlRd" }, "unit": "short" },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "piechart",
      "title": "Accepted vs rejected (all sources)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (outcome) (jobs_scraped_total)",
          "legendFormat": "{{outcome}}",
          "instant": true,
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "values": ["value"] },
        "pieType": "donut"
      },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Scrape throughput (jobs/min by outcome)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (outcome) (rate(jobs_scraped_total[5m])) * 60",
          "legendFormat": "{{outcome}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 15 } },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Event-loop lag (p90)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "nodejs_eventloop_lag_p90_seconds",
          "legendFormat": "p90 lag",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 15 } },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Heap used",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "nodejs_heap_size_used_bytes",
          "legendFormat": "heap used",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 15 } },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "CPU usage (cores)",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(process_cpu_seconds_total[1m])",
          "legendFormat": "cpu",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 15 } },
        "overrides": []
      }
    }
  ]
}
