{
  "uid": "job-queues",
  "title": "Job Queues",
  "tags": ["job-signal"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "bargauge",
      "title": "Jobs by queue & state (now)",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (queue, state) (bullmq_jobs) > 0",
          "legendFormat": "{{queue}} · {{state}}",
          "instant": true,
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "options": { "orientation": "horizontal", "displayMode": "gradient" },
      "fieldConfig": { "defaults": { "color": { "mode": "continuous-BlPu" }, "unit": "short" }, "overrides": [] }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Failed jobs by queue",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "bullmq_jobs{state=\"failed\"}",
          "legendFormat": "{{queue}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 20 } },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Backlog (waiting + active) by queue",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (queue) (bullmq_jobs{state=~\"waiting|active\"})",
          "legendFormat": "{{queue}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 20 } },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Completed jobs by queue",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "bullmq_jobs{state=\"completed\"}",
          "legendFormat": "{{queue}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 20 } },
        "overrides": []
      }
    }
  ]
}
